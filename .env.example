# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=virtual_company
POSTGRES_USER=vc_user
POSTGRES_PASSWORD=vc_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CHANNELS_REDIS_URL=redis://localhost:6379/3

# Encryption key for ProviderConfig.api_key (Fernet key, 32 url-safe base64 bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Default LLM provider for development
DEFAULT_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback providers
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
